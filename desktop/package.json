{
  "name": "cxema-v7-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "CXEMA V7 desktop shell for macOS",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack:mac": "electron-builder --mac dmg --publish never"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.cxema.v7.desktop",
    "productName": "CXEMA V7",
    "directories": {
      "output": "../dist-desktop"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.business"
    }
  }
}
